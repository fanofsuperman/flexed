local function safeHookFunction()
    if originalIndex then return originalIndex end
    originalIndex = hookmetamethod( game, "__index", function(t, k)
        if t:IsA("Mouse") and (k == "Hit" or k == "Target") then
            local mouseInstance = t
            if DaHoodSettings.SilentAim then
                local target = getNearestPointOfView()
                if target then
                    local predictedPosition = getPredictedPosition(target, "silent")
                    if predictedPosition then
                        if k == "Hit" then
                            return CFrame.new(predictedPosition)
                        elseif k == "Target" then
                            return target
                        end
                    end
                end
            elseif Aimlock.Enabled and Aimlock.IsLocked then
                if Aimlock.CurrentTarget and not isTargetValid(Aimlock.CurrentTarget) then
                    Aimlock.CurrentTarget = nil
                    Aimlock.IsLocked = false
                end
                if Aimlock.CurrentTarget then
                    local predictedPosition = getPredictedPosition(Aimlock.CurrentTarget)
                    if predictedPosition then
                        if k == "Hit" then
                            return CFrame.new(predictedPosition)
                        elseif k == "Target" then
                            return Aimlock.CurrentTarget
                        end
                    end
                end
            end
        end
        return originalIndex(t, k)
    end)
    return originalIndex
end

