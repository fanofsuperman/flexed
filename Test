local function isCharacterAlive(character)
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    return humanoid.Health > 0 and humanoid:GetState() ~= Enum.HumanoidStateType.Dead
end

local function isLocalPlayerAlive()
    if not LocalPlayer.Character then return false end
    return isCharacterAlive(LocalPlayer.Character)
end

local function isTargetValid(targetPart)
    if not targetPart then return false end
    local character = targetPart.Parent
    if not character then return false end
    if not isLocalPlayerAlive() then return false end
    local player = Players:GetPlayerFromCharacter(character)
    if player then
        return isCharacterAlive(character) and targetPart:IsDescendantOf(Workspace)
    else
        return DaHoodSettings.TargetNPCs and isCharacterAlive(character) and targetPart:IsDescendantOf(Workspace)
    end
    return false
end

local function findNPCBots()
    local npcs = {}
    local botsFolder = Workspace:FindFirstChild("Bots")
    if botsFolder then
        for _, bot in pairs(botsFolder:GetChildren()) do
            if bot:IsA("Model") and bot.Name == "Bot_1" then
                table.insert(npcs, bot)
            end
        end
    end
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "Bot_1" then
            local isPlayer = false
            for _, player in pairs(Players:GetPlayers()) do
                if player.Character == obj then
                    isPlayer = true
                    break
                end
            end
            if not isPlayer then
                table.insert(npcs, obj)
            end
        end
    end
    return npcs
end

local function getTargetPart(character)
    if not character then return nil end
    local targetPart = character:FindFirstChild(DaHoodSettings.TargetPart)
    if targetPart and targetPart:IsA("BasePart") then
        return targetPart
    end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if humanoidRootPart then
        return humanoidRootPart
    end
    local head = character:FindFirstChild("Head")
    if head then
        return head
    end
    return nil
end

local function isVisible(targetPart)
    if not DaHoodSettings.WallCheck then return true end
    local character = LocalPlayer.Character
    if not character then return false end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end
    local origin = CurrentCamera.CFrame.Position
    local targetPos = targetPart.Position
    local direction = (targetPos - origin).Unit
    local distance = (targetPos - origin).Magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {character, targetPart.Parent}
    local raycastResult = Workspace:Raycast(origin, direction * distance, raycastParams)
    return raycastResult == nil
end

function getNearestPlayer()
    local ClosestDistance = math.huge
    local ClosestPlayer = nil
    local CenterPosition = Vector2.new(CurrentCamera.ViewportSize.X / 2, CurrentCamera.ViewportSize.Y / 2)
    
    if not isLocalPlayerAlive() then return nil end
    
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local Character = Player.Character
            if Character and isCharacterAlive(Character) then
                local targetPart = getTargetPart(Character)
                if targetPart then
                    local Position, IsVisibleOnViewport = CurrentCamera:WorldToViewportPoint(targetPart.Position)
                    if IsVisibleOnViewport then
                        local screenPos = Vector2.new(Position.X, Position.Y)
                        local Distance = (CenterPosition - screenPos).Magnitude
                        if Distance < ClosestDistance then
                            if not DaHoodSettings.WallCheck or isVisible(targetPart) then
                                ClosestPlayer = targetPart
                                ClosestDistance = Distance
                            end
                        end
                    end
                end
            end
        end
    end
    
    if DaHoodSettings.TargetNPCs then
        local npcBots = findNPCBots()
        for _, npc in pairs(npcBots) do
            if isCharacterAlive(npc) then
                local targetPart = getTargetPart(npc)
                if targetPart then
                    local Position, IsVisibleOnViewport = CurrentCamera:WorldToViewportPoint(targetPart.Position)
                    if IsVisibleOnViewport then
                        local screenPos = Vector2.new(Position.X, Position.Y)
                        local Distance = (CenterPosition - screenPos).Magnitude
                        if Distance < ClosestDistance then
                            if not DaHoodSettings.WallCheck or isVisible(targetPart) then
                                ClosestPlayer = targetPart
                                ClosestDistance = Distance
                            end
                        end
                    end
                end
            end
        end
    end
    
    return ClosestPlayer
end

